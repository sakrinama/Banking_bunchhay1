package com.titan.titancorebanking.cbdc;

import jakarta.persistence.*;
import lombok.*;
import java.math.BigDecimal;
import java.time.LocalDateTime;

/**
 * Task 2: Tracks fiat-to-CBDC token minting operations.
 * When fiat is locked in our ledger, a corresponding CBDC token is minted
 * on the Central Bank's blockchain network.
 */
@Entity
@Table(name = "cbdc_mint_record", indexes = {
    @Index(name = "idx_cbdc_account", columnList = "accountId"),
    @Index(name = "idx_cbdc_tx_hash", columnList = "blockchainTxHash")
})
@Getter @Setter @Builder @NoArgsConstructor @AllArgsConstructor
public class CbdcMintRecord {

    @Id @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    @Column(nullable = false)
    private Long accountId;

    @Column(nullable = false, precision = 30, scale = 8)
    private BigDecimal fiatAmount;

    @Column(nullable = false, length = 3)
    private String fiatCurrency;

    @Column(nullable = false, precision = 30, scale = 8)
    private BigDecimal tokenAmount; // 1:1 peg

    @Column(nullable = false, length = 10)
    private String tokenSymbol; // e.g. "eKHR", "eDollar"

    @Column(nullable = false, length = 66)
    private String blockchainTxHash;

    @Column(nullable = false, length = 42)
    private String recipientWalletAddress;

    @Enumerated(EnumType.STRING)
    @Column(nullable = false)
    private MintStatus status;

    @Column(nullable = false, updatable = false)
    private LocalDateTime createdAt;

    private LocalDateTime confirmedAt;

    @Column(length = 500)
    private String errorMessage;

    @PrePersist
    protected void onCreate() { createdAt = LocalDateTime.now(); }

    public enum MintStatus { PENDING, CONFIRMED, FAILED, BURNED }
}
