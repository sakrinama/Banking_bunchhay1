package com.titan.titancorebanking.htlc;

import jakarta.persistence.*;
import lombok.*;
import java.math.BigDecimal;
import java.time.LocalDateTime;

/**
 * Task 9: Hash Time-Locked Contract (HTLC) for B2B Escrow
 *
 * Funds are locked cryptographically. Receiver must provide the preimage
 * (secret) whose SHA-256 hash matches the hashLock within 60 minutes.
 * If not, the contract auto-expires and refunds the sender.
 */
@Entity
@Table(name = "htlc_contract", indexes = {
    @Index(name = "idx_htlc_hash_lock", columnList = "hashLock"),
    @Index(name = "idx_htlc_status_expires", columnList = "status, expiresAt")
})
@Getter @Setter @Builder @NoArgsConstructor @AllArgsConstructor
public class HtlcContract {

    @Id
    @Column(length = 36)
    private String contractId; // UUID

    @Column(nullable = false)
    private Long senderAccountId;

    @Column(nullable = false)
    private Long receiverAccountId;

    @Column(nullable = false, precision = 30, scale = 2)
    private BigDecimal amount;

    @Column(nullable = false, length = 3)
    private String currency;

    /** SHA-256 hash of the secret preimage */
    @Column(nullable = false, length = 64)
    private String hashLock;

    /** Revealed by receiver to claim funds */
    @Column(length = 128)
    private String preimage;

    @Enumerated(EnumType.STRING)
    @Column(nullable = false)
    private HtlcStatus status;

    @Column(nullable = false, updatable = false)
    private LocalDateTime createdAt;

    @Column(nullable = false)
    private LocalDateTime expiresAt;

    private LocalDateTime settledAt;

    @Column(length = 500)
    private String memo;

    @PrePersist
    protected void onCreate() { createdAt = LocalDateTime.now(); }

    public enum HtlcStatus { LOCKED, CLAIMED, EXPIRED, REFUNDED }
}
