package com.titan.titancorebanking.failsafe;

import lombok.RequiredArgsConstructor;
import org.springframework.http.ResponseEntity;
import org.springframework.security.access.prepost.PreAuthorize;
import org.springframework.web.bind.annotation.*;

@RestController
@RequestMapping("/api/v1/failsafe")
@RequiredArgsConstructor
public class DeadMansSwitchController {

    private final DeadMansSwitchService dmsService;

    public record HeartbeatRequest(String timestampEpochMs, String signature) {}
    public record TripRequest(String reason, String adminSignature) {}

    /** Executive sends signed heartbeat every 24h */
    @PostMapping("/heartbeat")
    public ResponseEntity<String> heartbeat(@RequestBody HeartbeatRequest req) {
        try {
            dmsService.receiveHeartbeat(req.timestampEpochMs(), req.signature());
            return ResponseEntity.ok("{\"status\":\"HEARTBEAT_ACCEPTED\"}");
        } catch (Exception e) {
            return ResponseEntity.status(403).body("{\"error\":\"" + e.getMessage() + "\"}");
        }
    }

    /** Manual lockdown trigger (hostile takeover / ransomware) */
    @PostMapping("/trip")
    @PreAuthorize("hasRole('ADMIN')")
    public ResponseEntity<String> manualTrip(@RequestBody TripRequest req) {
        try {
            dmsService.manualTrip(req.reason(), req.adminSignature());
            return ResponseEntity.ok("{\"status\":\"LOCKDOWN_ACTIVATED\"}");
        } catch (Exception e) {
            return ResponseEntity.status(403).body("{\"error\":\"" + e.getMessage() + "\"}");
        }
    }

    @GetMapping("/status")
    @PreAuthorize("hasRole('ADMIN')")
    public ResponseEntity<String> status() {
        boolean locked = dmsService.isLockdownActive();
        return ResponseEntity.ok("{\"lockdown\":" + locked + "}");
    }
}
