<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="SECURE_CONSOLE" class="com.titan.notifications.logging.SecureLogAppender"/>
    
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/notifications.log</file>
        <filter class="com.titan.notifications.logging.PiiRedactionFilter"/>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/notifications-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>
    
    <root level="INFO">
        <appender-ref ref="SECURE_CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
